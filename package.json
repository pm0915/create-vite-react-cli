{
  "name": "create-vite-react-cli",
  "version": "0.1.0",
  "description": "🛠️ The recommended way to start a Vite-powered React project",
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "bin": {
    "create-vite-react-cli": "bundle.js"
  },
  "files": [
    "locales",
    "bundle.js",
    "templates",
    "!templates/**/node_modules/.bin/*"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "build": "rollup -c",
    "dev": "node bundle.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "snapshot": "zx ./scripts/snapshot.mjs",
    "pretest": "pnpm run build && pnpm run snapshot",
    "test": "zx ./scripts/test.mjs",
    "test:unit": "vitest",
    "preversion": "git fetch && git status -uno | grep -q 'Your branch is up to date'",
    "postversion": "zx ./scripts/postversion.mjs",
    "prepublishOnly": "pnpm run build",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pm0915/create-vite-react-cli.git"
  },
  "keywords": [
    "vite",
    "react",
    "scaffold",
    "cli",
    "create-react-app",
    "template"
  ],
  "author": "Miles Pan",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/pm0915/create-vite-react-cli/issues"
  },
  "homepage": "https://github.com/pm0915/create-vite-react-cli#readme",
  "devDependencies": {
    "@clack/prompts": "^0.11.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@tsconfig/node24": "^24.0.3",
    "@types/eslint": "^9.6.1",
    "@types/node": "^25.0.3",
    "ejs": "^3.1.10",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^17.23.1",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.2.7",
    "picocolors": "^1.1.1",
    "prettier": "^3.7.4",
    "rollup": "^4.54.0",
    "tslib": "^2.8.1",
    "typescript-eslint": "^8.51.0",
    "vitest": "^4.0.16",
    "zx": "^8.8.5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss}": [
      "prettier --write"
    ]
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
